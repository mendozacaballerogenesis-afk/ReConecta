body{
    margin:0;
    font-family:Arial, sans-serif;
    background:linear-gradient(135deg,#d8f3dc,#b7e4c7,#95d5b2);
    text-align:center;
    color:#1b4332;
}

header{
    padding:40px 20px 20px;
}

h1{
    font-size:40px;
}

h2{
    font-size:22px;
    font-weight:normal;
}

main{
    padding:20px;
}

img{
    max-width:250px;
}

p{
    font-size:20px;
    max-width:700px;
    margin:auto;
    line-height:1.6;
}

button{
    margin-top:30px;
    background:#2d6a4f;
    color:white;
    border:none;
    padding:15px 35px;
    border-radius:30px;
    font-size:20px;
    cursor:pointer;
}

button:hover{
    background:#40916c;
}

footer{
    margin-top:50px;
    padding:20px;
    background:#1b4332;
    color:white;
}

