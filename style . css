*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:linear-gradient(135deg,#ffd6e7,#d9f4ff,#fff4c2);
    min-height:100vh;
}

header{
    text-align:center;
    padding:50px 20px;
}

header img{
    width:150px;
    margin-bottom:20px;
}

h1{
    font-size:48px;
    color:#ff4f8b;
}

h2{
    font-size:22px;
    color:#555;
    margin-top:15px;
}

button{
    margin-top:35px;
    padding:15px 35px;
    border:none;
    border-radius:30px;
    background:#ff6fa8;
    color:white;
    font-size:18px;
    cursor:pointer;
}

button:hover{
    background:#ff4f8b;
}
